def lan_truyen_vung_loi_bfs(dist_matrix, mknn, gamma_list, n_clusters):
    n_pts = len(dist_matrix)
    labels = [0] * n_pts
    cluster_centers = []

    # 1. Khởi tạo tâm cụm từ danh sách Gamma cao nhất
    for i in range(n_clusters):
        score, point_idx, r_val, d_val = gamma_list[i]
        cluster_centers.append(point_idx)
        labels[point_idx] = i + 1

    # 2. Lan truyền vùng lõi bằng BFS
    for ci in cluster_centers:
        Que = []
        lci = labels[ci]
        for neighbor in mknn[ci]:
            if labels[neighbor] == 0:
                labels[neighbor] = lci
                Que.append(neighbor)
        while len(Que) > 0:
            xq = Que[0]
            tong_khoang_cach = sum(dist_matrix[xq][xj] for xj in mknn[xq])
            so_luong_mknn = len(mknn[xq])
            khoang_cach_trung_binh = tong_khoang_cach / so_luong_mknn if so_luong_mknn > 0 else 0
            for xp in mknn[xq]:
                if labels[xp] == 0 and dist_matrix[xp][xq] <= khoang_cach_trung_binh:
                    labels[xp] = lci
                    Que.append(xp)
            Que.pop(0)

    return labels, cluster_centers
def lan_truyen_xac_suat(dist_matrix, S, mknn, labels, n_clusters):
    n = len(dist_matrix)

    # Tập các điểm chưa được gán nhãn sau thuật toán BFS
    Dn = [i for i in range(n) if labels[i] == 0]

    # Ma trận xác suất thuộc cụm P và ma trận lưu xác suất max MP
    P = [[0.0] * (n_clusters + 1) for _ in range(n)]
    MP = [[0.0, 0] for _ in range(n)]

    # Tính xác suất ban đầu cho từng điểm chưa gán
    for xi in Dn:
        for t in range(1, n_clusters + 1):
            p_ict = 0.0
            for xj in mknn[xi]:
                if labels[xj] == t:
                    mau_so = sum(S[q][xj] for q in mknn[xj])
                    w_ij = S[xi][xj] / mau_so if mau_so > 0 else 0.0
                    p_ict += w_ij * S[xi][xj]
            P[xi][t] = p_ict

        tong_P_xi = sum(P[xi])
        if tong_P_xi > 0:
            for t in range(1, n_clusters + 1):
                P[xi][t] = P[xi][t] / tong_P_xi

        max_prob = max(P[xi][1:])
        best_cluster = P[xi].index(max_prob, 1) if max_prob > 0 else 0
        MP[xi][0] = max_prob
        MP[xi][1] = best_cluster

    # Tìm điểm có xác suất lớn nhất để bắt đầu gán
    best_p = -1
    max_val = -1.0
    for i in Dn:
        if MP[i][0] > max_val:
            max_val = MP[i][0]
            best_p = i

    flag = 1 if best_p != -1 and P[best_p][MP[best_p][1]] != 0 else 0

    # Vòng lặp gán nhãn xác suất lan truyền
    while flag == 1:
        p = best_p
        labels[p] = MP[p][1]
        for t in range(1, n_clusters + 1):
            P[p][t] = 0.0
        MP[p] = [0.0, 0]

        # Cập nhật xác suất cho các điểm lân cận chưa gán nhãn
        for xq in mknn[p]:
            if labels[xq] == 0:
                mau_so = sum(S[nb][p] for nb in mknn[p])
                w_pq = S[xq][p] / mau_so if mau_so > 0 else 0.0
                cluster_q = MP[xq][1]
                if cluster_q != 0:
                    P[xq][cluster_q] += w_pq * S[xq][p]

                max_prob_q = max(P[xq][1:])
                best_cluster_q = P[xq].index(max_prob_q, 1) if max_prob_q > 0 else 0
                MP[xq][0] = max_prob_q
                MP[xq][1] = best_cluster_q

        # Tìm lại điểm có xác suất lớn nhất trong tập còn lại
        best_p = -1
        max_val = -1.0
        for i in Dn:
            if labels[i] == 0 and MP[i][0] > max_val:
                max_val = MP[i][0]
                best_p = i

        if best_p == -1 or P[best_p][MP[best_p][1]] == 0:
            flag = 0

    # Giai đoạn vét cạn: Gán nốt các điểm cô lập (nếu có) theo láng giềng đã có nhãn
    while True:
        co_thay_doi = False
        for xj in Dn:
            if labels[xj] == 0:
                for xl in mknn[xj]:
                    if labels[xl] != 0:
                        labels[xj] = labels[xl]
                        co_thay_doi = True
                        break
        if not co_thay_doi:
            break

    # Chốt chặn cuối cùng (nếu dữ liệu quá nhiễu, điểm hoàn toàn cô lập)
    for xj in Dn:
        if labels[xj] == 0:
            labels[xj] = 1

    return labels
def calculate_internal_metrics(X_norm, labels, dist_matrix):
    X_data = np.array(X_norm)
    labels_arr = np.array(labels)
    unique_labels = np.unique(labels_arr)

    if len(unique_labels) < 2: return None

    sil = silhouette_score(X_data, labels_arr)
    db = davies_bouldin_score(X_data, labels_arr)
    ch = calinski_harabasz_score(X_data, labels_arr)

    overall_mean = np.mean(X_data, axis=0)
    wss = 0
    bss = 0
    for cluster in unique_labels:
        cluster_points = X_data[labels_arr == cluster]
        cluster_mean = np.mean(cluster_points, axis=0)
        wss += np.sum((cluster_points - cluster_mean)**2)
        bss += len(cluster_points) * np.sum((cluster_mean - overall_mean)**2)

    wb = wss / bss if bss != 0 else 0

    def dunn_index(labels_array, dist_mtx, unq_labels):
        intra_dist = []
        inter_dist = []
        for i in unq_labels:
            idx = np.where(labels_array == i)[0]
            if len(idx) > 1:
                max_d = 0
                for a in range(len(idx)):
                    for b in range(a + 1, len(idx)):
                        d = dist_mtx[idx[a]][idx[b]]
                        if d > max_d: max_d = d
                intra_dist.append(max_d)

            for j in unq_labels:
                if i < j:
                    idx_i = np.where(labels_array == i)[0]
                    idx_j = np.where(labels_array == j)[0]
                    min_d = float('inf')
                    for a in idx_i:
                        for b in idx_j:
                            if dist_mtx[a][b] < min_d: min_d = dist_mtx[a][b]
                    inter_dist.append(min_d)

        return min(inter_dist) / max(intra_dist) if intra_dist and inter_dist else 0

    dunn = dunn_index(labels_arr, dist_matrix, unique_labels)
    return sil, db, ch, wss, bss, wb, dunn
