def thu_thap_du_lieu(file_path):
    X = []
    ids = []
    try:
        with open(file_path, 'r') as file:
            la_dong_dau_tien = True
            for line in file:
                if la_dong_dau_tien:
                    la_dong_dau_tien = False
                    continue
                line = line.strip()
                if not line: continue
                parts = line.split()
                X.append([float(parts[1]), float(parts[2])])
                ids.append(parts[0])
        return X, ids
    except FileNotFoundError:
        print("Lỗi: Không tìm thấy file.")
        return None, None


def xu_ly_du_lieu(X):
    n_pts = len(X)
    so_dac_trung = len(X[0])

    # Chuẩn hóa Min-Max
    min_val = [float('inf')] * so_dac_trung
    max_val = [-float('inf')] * so_dac_trung
    for i in range(n_pts):
        for j in range(so_dac_trung):
            if X[i][j] < min_val[j]: min_val[j] = X[i][j]
            if X[i][j] > max_val[j]: max_val[j] = X[i][j]

    X_norm = [[0.0] * so_dac_trung for _ in range(n_pts)]
    for i in range(n_pts):
        for j in range(so_dac_trung):
            mau_so = max_val[j] - min_val[j]
            X_norm[i][j] = (X[i][j] - min_val[j]) / mau_so if mau_so > 0 else 0

    # Tính ma trận
    def tinh_khoang_cach(p1, p2): return math.sqrt((p1[0]-p2[0])**2 + (p1[1]-p2[1])**2)
    dist_matrix = [[0.0] * n_pts for _ in range(n_pts)]
    S = [[0.0] * n_pts for _ in range(n_pts)]
    for i in range(n_pts):
        for j in range(n_pts):
            dist_matrix[i][j] = tinh_khoang_cach(X_norm[i], X_norm[j])
            S[i][j] = 1 - (dist_matrix[i][j] / (dist_matrix[i][j] + 1))
    return X_norm, dist_matrix, S


def xaydung_mang_mknn(dist_matrix, k_val):
    n_pts = len(dist_matrix)
    knn = []
    for i in range(n_pts):
        dists_with_index = [(dist_matrix[i][j], j) for j in range(n_pts) if i != j]
        dists_with_index.sort()
        knn.append([dists_with_index[m][1] for m in range(k_val)])
    rnn = [[] for _ in range(n_pts)]
    for i in range(n_pts):
        for neighbor in knn[i]: rnn[neighbor].append(i)
    mknn = [[] for _ in range(n_pts)]
    for i in range(n_pts):
        intersect = [val for val in knn[i] if val in rnn[i]]
        mknn[i] = intersect if len(intersect) > 0 else knn[i][:math.ceil(k_val/2)]
    return mknn


def tinh_rho_delta_gamma(dist_matrix, mknn, dung_trung_binh_dieu_hoa=False):
    n_pts = len(dist_matrix)

    # Tính rho
    rho = [0.0] * n_pts
    for i in range(n_pts):
        sum_dist = sum(dist_matrix[i][nb] for nb in mknn[i])
        rho[i] = (len(mknn[i]) ** 2) / sum_dist if sum_dist > 0 else 0

    # Tính delta
    delta = [0.0] * n_pts
    rho_kem_chi_so = sorted([(rho[i], i) for i in range(n_pts)], reverse=True)

    diem_max_rho = rho_kem_chi_so[0][1]
    delta[diem_max_rho] = max(dist_matrix[diem_max_rho])

    for i in range(1, n_pts):
        idx_curr = rho_kem_chi_so[i][1]
        ds = []

        for j in range(i):
            idx_truoc = rho_kem_chi_so[j][1]

            if rho[idx_truoc] > rho[idx_curr]:
                ds.append(dist_matrix[idx_curr][idx_truoc])

            elif dist_matrix[idx_curr][idx_truoc] == 0:
                ds.append(0)

        delta[idx_curr] = min(ds) if ds else max(dist_matrix[idx_curr])

    # Tính gamma
    gamma_list = []

    for i in range(n_pts):

        if dung_trung_binh_dieu_hoa:
            mau_so = rho[i] + delta[i]
            gamma_val = (2 * rho[i] * delta[i]) / mau_so if mau_so > 0 else 0
        else:
            gamma_val = rho[i] * delta[i]

        gamma_list.append((gamma_val, i, rho[i], delta[i]))

    gamma_list.sort(key=lambda x: x[0], reverse=True)

    return rho, delta, gamma_list
